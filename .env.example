# Copy this file to .env.local and fill in real values.

# Neon Postgres connection string (Project Dashboard -> Connect)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Anthropic API key (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Hard monthly cap on Claude API calls (safety limit)
CLAUDE_MONTHLY_CAP=5000

# Public URL of the deployed site, used for canonical OG metadata.
# Example: https://isnad.onrender.com  (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
