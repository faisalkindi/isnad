# Copy this file to .env.local and fill in real values.

# Neon Postgres connection string (Project Dashboard -> Connect)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Anthropic API key (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Hard monthly cap on Claude API calls (safety limit)
CLAUDE_MONTHLY_CAP=5000

# Public URL of the deployed site, used for canonical OG metadata.
# Example: https://isnad.onrender.com  (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LLM provider selection. Default: anthropic + claude-sonnet-4-6.
# To switch to a cheaper model on OpenRouter, uncomment these two:
# LLM_PROVIDER=openrouter
# LLM_MODEL=qwen/qwen3.6-flash   # 9/10 match vs Sonnet in our shootout
# LLM_MODEL=deepseek/deepseek-v4-flash  # 8/10 match, 13× cheaper

# OpenRouter API key (required when LLM_PROVIDER=openrouter)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
